{
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "inlineSourceMap": false,
    "inlineSources": false,
    "noImplicitAny": false,
    "diagnostics": false,
    "listFiles": false,
    "outDir": "dist",
    "noEmitOnError": false,
    "strict": true,
    "types": ["gapi", "gapi.auth2", "gapi.client", "gapi.client.tasks"]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/**/*.test.ts"
  ]
}
